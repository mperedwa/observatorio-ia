{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "changelog.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["fecha", "tipo", "actualizacion", "fuente"],
    "additionalProperties": false,
    "properties": {
      "fecha": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "tipo": { "enum": ["legislacion", "institucion", "indicador", "proyecto", "recurso"] },
      "actualizacion": { "$ref": "#/definitions/bilingual" },
      "fuente": { "$ref": "#/definitions/bilingual" },
      "fuente_url": { "type": "string", "format": "uri" },
      "commit_sha": { "type": "string", "pattern": "^[a-f0-9]{7,40}$" }
    }
  },
  "definitions": {
    "bilingual": {
      "type": "object",
      "required": ["es", "en"],
      "additionalProperties": false,
      "properties": {
        "es": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      }
    }
  }
}
