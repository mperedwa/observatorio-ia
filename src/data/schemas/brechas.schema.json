{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "brechas.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "capacidad", "paisReferencia", "evidenciaReferencia", "estadoCR", "porQueImporta", "fuenteUrl"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "capacidad": { "$ref": "#/definitions/bilingual" },
      "paisReferencia": { "$ref": "#/definitions/bilingual" },
      "evidenciaReferencia": { "$ref": "#/definitions/bilingual" },
      "estadoCR": { "$ref": "#/definitions/bilingual" },
      "porQueImporta": { "$ref": "#/definitions/bilingual" },
      "fuenteUrl": { "type": "string", "format": "uri" }
    }
  },
  "definitions": {
    "bilingual": {
      "type": "object",
      "required": ["es", "en"],
      "additionalProperties": false,
      "properties": {
        "es": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      }
    }
  }
}
