{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "legislacion.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["numero", "titulo", "resumen", "estado", "comision", "presentado", "fuenteUrl"],
    "additionalProperties": false,
    "properties": {
      "numero": { "type": "string", "pattern": "^[0-9]{2,3}\\.[0-9]{3}$" },
      "titulo": { "$ref": "#/definitions/bilingual" },
      "resumen": { "$ref": "#/definitions/bilingual" },
      "estado": {
        "type": "string",
        "enum": ["en-comision", "dictaminado", "primer-debate", "segundo-debate", "archivado", "aprobada"]
      },
      "comision": { "$ref": "#/definitions/bilingual" },
      "presentado": { "type": "string", "pattern": "^[0-9]{4}$" },
      "fuenteUrl": { "type": "string", "format": "uri" }
    }
  },
  "definitions": {
    "bilingual": {
      "type": "object",
      "required": ["es", "en"],
      "additionalProperties": false,
      "properties": {
        "es": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      }
    }
  }
}
