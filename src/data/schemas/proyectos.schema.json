{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "proyectos.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "titulo",
      "institucionId",
      "categoria",
      "estado",
      "descripcion",
      "fuenteUrl"
    ],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "titulo": {
        "$ref": "#/definitions/bilingual"
      },
      "institucionId": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "categoria": {
        "type": "string",
        "enum": [
          "judicial",
          "salud",
          "educacion",
          "fiscal",
          "infraestructura",
          "agricultura"
        ]
      },
      "estado": {
        "type": "string",
        "enum": [
          "operativo",
          "piloto",
          "planificado"
        ]
      },
      "descripcion": {
        "$ref": "#/definitions/bilingual"
      },
      "resultado": {
        "$ref": "#/definitions/bilingual"
      },
      "contexto": {
        "$ref": "#/definitions/bilingual"
      },
      "desde": {
        "type": "string",
        "pattern": "^[0-9]{4}$"
      },
      "fuenteUrl": {
        "type": "string",
        "format": "uri"
      }
    }
  },
  "definitions": {
    "bilingual": {
      "type": "object",
      "required": [
        "es",
        "en"
      ],
      "additionalProperties": false,
      "properties": {
        "es": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
